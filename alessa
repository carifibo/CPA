<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>CPA · Comissão Própria de Avaliação — Centro Universitário UniLS</title>
<meta name="description" content="Entenda o que é, como funciona e por que participar da Comissão Própria de Avaliação (CPA) da UniLS.">
<style>

/* ===================================================================
   TOKENS
=================================================================== */
:root{
  --bg-deep:#3E0A18;
  --bg-deep-2:#54091D;
  --bg-panel:#6B0F26;
  --bg-panel-2:#7D1129;
  --red-primary:#C8102E;
  --red-primary-2:#A80E27;
  --red-bright:#FF4D5E;
  --red-bright-2:#FF6B6B;
  --cream:#FFF7F1;
  --cream-dim:#FFE3DD;
  --ink:#330810;
  --ink-soft:#5C1626;
  --gold:#D8A857;
  --gold-soft:#EFD49C;
  --line:rgba(255,247,241,0.16);
  --line-soft:rgba(255,247,241,0.08);

  --font-display: 'Iowan Old Style','Palatino Linotype','URW Palladio L',Georgia,serif;
  --font-body: -apple-system, BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;
  --font-round: ui-rounded, -apple-system, 'SF Pro Rounded', var(--font-body);

  --radius-s:10px;
  --radius-m:18px;
  --radius-l:28px;
  --shadow-soft: 0 14px 34px rgba(20,2,7,0.35);
  --shadow-pop: 0 20px 48px rgba(20,2,7,0.5);
  --ease: cubic-bezier(.22,.68,.36,1);
}

*,*::before,*::after{ box-sizing:border-box; }
html{ -webkit-text-size-adjust:100%; text-size-adjust:100%; scroll-behavior:smooth; }
body{
  margin:0;
  font-family:var(--font-body);
  color:var(--cream);
  background:
    radial-gradient(120% 90% at 12% -10%, var(--bg-deep-2) 0%, transparent 55%),
    radial-gradient(140% 100% at 110% 0%, var(--bg-panel-2) 0%, transparent 50%),
    linear-gradient(180deg, var(--bg-deep) 0%, var(--bg-deep) 100%);
  background-color:var(--bg-deep);
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
}
img{ max-width:100%; display:block; }
button{ font-family:inherit; }
a{ color:inherit; }
h1,h2,h3,h4{ margin:0; font-family:var(--font-display); font-weight:600; letter-spacing:.01em; }
p{ margin:0; }
ul{ margin:0; padding:0; list-style:none; }

.visually-hidden{
  position:absolute !important; width:1px; height:1px; padding:0; margin:-1px;
  overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0;
}

:focus-visible{
  outline:3px solid var(--gold-soft);
  outline-offset:3px;
  border-radius:6px;
}

@media (prefers-reduced-motion: reduce){
  *,*::before,*::after{
    animation-duration:0.001ms !important;
    animation-iteration-count:1 !important;
    transition-duration:0.001ms !important;
    scroll-behavior:auto !important;
  }
}

/* ===================================================================
   LAYOUT HELPERS
=================================================================== */
.wrap{
  width:100%;
  max-width:1080px;
  margin:0 auto;
  padding-left:24px;
  padding-right:24px;
}
.section{
  position:relative;
  padding:88px 0 96px;
}
.section--tight{ padding:64px 0; }
.section--panel{
  background:linear-gradient(180deg, var(--bg-panel) 0%, var(--bg-panel-2) 100%);
  border-top:1px solid var(--line-soft);
  border-bottom:1px solid var(--line-soft);
}
.kicker{
  display:inline-flex;
  align-items:center;
  gap:8px;
  font-family:var(--font-round);
  font-size:12.5px;
  font-weight:700;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:var(--gold-soft);
  margin-bottom:14px;
}
.kicker::before{
  content:"";
  width:18px; height:1.5px;
  background:var(--gold-soft);
  display:inline-block;
}
.section-head{
  max-width:680px;
  margin-bottom:40px;
}
.section-head h2{
  font-size:clamp(28px,4.2vw,40px);
  line-height:1.15;
  color:var(--cream);
}
.section-lede{
  margin-top:16px;
  font-size:17px;
  line-height:1.65;
  color:var(--cream-dim);
}
.section-lede + .section-lede{ margin-top:12px; }

.icon{
  width:22px; height:22px;
  stroke:currentColor;
  fill:none;
  stroke-width:1.6;
  stroke-linecap:round;
  stroke-linejoin:round;
  flex-shrink:0;
}
.icon--filled{ fill:currentColor; stroke:none; }

/* ===================================================================
   HEADER / NAV
=================================================================== */
.topbar{
  position:sticky;
  top:0;
  z-index:50;
  background:rgba(62,10,24,0.86);
  -webkit-backdrop-filter:blur(10px);
  backdrop-filter:blur(10px);
  border-bottom:1px solid var(--line-soft);
}
.topbar-inner{
  max-width:1080px;
  margin:0 auto;
  padding:12px 20px;
  display:flex;
  align-items:center;
  gap:18px;
}
.brand{
  display:flex;
  align-items:center;
  gap:10px;
  font-family:var(--font-round);
  font-weight:800;
  font-size:15px;
  color:var(--cream);
  white-space:nowrap;
  text-decoration:none;
  flex-shrink:0;
}
.brand-logo{
  height:30px;
  width:auto;
  display:block;
  flex-shrink:0;
}

.pillnav{
  display:flex;
  gap:6px;
  overflow-x:auto;
  -webkit-overflow-scrolling:touch;
  scrollbar-width:none;
  padding-bottom:2px;
}
.pillnav::-webkit-scrollbar{ display:none; }
.pillnav a{
  flex-shrink:0;
  display:inline-flex;
  align-items:center;
  gap:6px;
  padding:8px 14px;
  border-radius:999px;
  font-family:var(--font-round);
  font-size:13px;
  font-weight:600;
  color:var(--cream-dim);
  text-decoration:none;
  border:1px solid transparent;
  transition:background .2s var(--ease), color .2s var(--ease), border-color .2s var(--ease);
  white-space:nowrap;
}
.pillnav a .icon{ width:15px;height:15px; }
.pillnav a:hover{ color:var(--cream); background:rgba(255,247,241,0.08); }
.pillnav a.is-active{
  color:var(--ink);
  background:var(--gold-soft);
  border-color:var(--gold-soft);
}

/* ===================================================================
   HERO
=================================================================== */
.hero{
  position:relative;
  padding:64px 0 70px;
  overflow:hidden;
}
.hero::before{
  content:"";
  position:absolute; inset:-20% -10% auto -10%;
  height:140%;
  background:
    radial-gradient(60% 60% at 80% 10%, rgba(255,77,94,0.25), transparent 60%),
    radial-gradient(45% 45% at 5% 30%, rgba(216,168,87,0.14), transparent 60%);
  pointer-events:none;
}
.hero-grid{
  position:relative;
  display:flex;
  align-items:center;
  gap:56px;
  flex-wrap:wrap;
}
.hero-copy{ flex:1 1 420px; min-width:280px; }
.hero-copy h1{
  font-size:clamp(34px,5.4vw,56px);
  line-height:1.08;
  color:var(--cream);
}
.hero-copy h1 em{
  font-style:normal;
  color:var(--gold-soft);
}
.hero-sub{
  margin-top:20px;
  font-size:18px;
  line-height:1.6;
  color:var(--cream-dim);
  max-width:46ch;
}
.hero-ctas{
  margin-top:32px;
  display:flex;
  gap:14px;
  flex-wrap:wrap;
}
.btn{
  display:inline-flex;
  align-items:center;
  gap:8px;
  font-family:var(--font-round);
  font-weight:700;
  font-size:15px;
  padding:14px 24px;
  border-radius:999px;
  border:1px solid transparent;
  cursor:pointer;
  text-decoration:none;
  transition:transform .18s var(--ease), box-shadow .18s var(--ease), background .18s var(--ease);
}
.btn:active{ transform:translateY(1px) scale(.99); }
.btn--primary{
  background:linear-gradient(145deg, var(--red-bright), var(--red-primary));
  color:var(--cream);
  box-shadow:0 14px 30px rgba(200,16,46,0.45);
}
.btn--primary:hover{ box-shadow:0 18px 38px rgba(200,16,46,0.55); transform:translateY(-1px); }
.btn--ghost{
  background:transparent;
  color:var(--cream);
  border-color:var(--line);
}
.btn--ghost:hover{ background:rgba(255,247,241,0.08); }
.btn--gold{
  background:linear-gradient(145deg, var(--gold-soft), var(--gold));
  color:var(--ink);
  box-shadow:0 14px 30px rgba(216,168,87,0.35);
}
.btn--gold:hover{ transform:translateY(-1px); }
.btn[disabled]{ opacity:.5; cursor:not-allowed; transform:none !important; }

.hero-facts{
  margin-top:30px;
  display:flex;
  gap:10px;
  flex-wrap:wrap;
}
.fact-pill{
  display:inline-flex;
  align-items:center;
  gap:7px;
  font-size:12.5px;
  font-family:var(--font-round);
  font-weight:600;
  color:var(--cream-dim);
  background:rgba(255,247,241,0.06);
  border:1px solid var(--line-soft);
  padding:7px 12px;
  border-radius:999px;
}
.fact-pill .icon{ width:14px;height:14px; color:var(--gold-soft); }

/* --- seal --- */
.hero-seal{
  flex:0 0 auto;
  width:min(260px, 50vw);
  margin:0 auto;
}
.seal{
  position:relative;
  width:100%;
  aspect-ratio:1/1;
}
.seal svg{ width:100%; height:100%; display:block; }
.seal .ring{
  transform-origin:100px 100px;
  animation:seal-spin 46s linear infinite;
}
@keyframes seal-spin{ to{ transform:rotate(360deg); } }
.seal-core{
  position:absolute; inset:0;
  display:flex; align-items:center; justify-content:center;
}
.seal-core img{
  width:74%;
  height:auto;
  border-radius:50%;
  filter:drop-shadow(0 6px 16px rgba(0,0,0,0.45));
}

.logo-banner{
  margin-top:46px;
  border-radius:var(--radius-m);
  overflow:hidden;
  border:1px solid var(--line-soft);
  box-shadow:var(--shadow-soft);
}
.logo-banner img{ width:100%; height:auto; }



/* ===================================================================
   FACT BADGES ROW (about section)
=================================================================== */
.badge-row{
  display:flex; gap:12px; flex-wrap:wrap; margin-top:28px;
}
.badge{
  display:inline-flex; align-items:center; gap:8px;
  background:rgba(255,247,241,0.07);
  border:1px solid var(--line-soft);
  padding:10px 16px;
  border-radius:var(--radius-s);
  font-family:var(--font-round);
  font-size:13.5px; font-weight:600;
  color:var(--cream);
}
.badge .icon{ width:17px;height:17px; color:var(--gold-soft); }

/* ===================================================================
   GENERIC CARD GRID
=================================================================== */
.grid{
  display:grid;
  gap:16px;
  grid-template-columns:repeat(auto-fit, minmax(220px,1fr));
}
.grid--tight{ grid-template-columns:repeat(auto-fit, minmax(170px,1fr)); }

/* ===================================================================
   FLIP CARD
=================================================================== */
.flip{
  appearance:none;
  -webkit-appearance:none;
  background:none;
  border:none;
  padding:0;
  cursor:pointer;
  perspective:1200px;
  text-align:left;
  width:100%;
  color:inherit;
}
.flip-inner{
  position:relative;
  width:100%;
  min-height:168px;
  border-radius:var(--radius-m);
  transition:transform .55s var(--ease);
  transform-style:preserve-3d;
}
.flip.is-flipped .flip-inner{ transform:rotateY(180deg); }
.flip-face{
  position:absolute; inset:0;
  -webkit-backface-visibility:hidden;
  backface-visibility:hidden;
  border-radius:var(--radius-m);
  padding:22px;
  display:flex;
  flex-direction:column;
  gap:12px;
}
.flip-face--front{
  background:linear-gradient(160deg, rgba(255,247,241,0.09), rgba(255,247,241,0.03));
  border:1px solid var(--line-soft);
  justify-content:space-between;
}
.flip-face--back{
  background:linear-gradient(160deg, var(--gold-soft), var(--gold));
  color:var(--ink);
  transform:rotateY(180deg);
  justify-content:center;
}
.flip-icon{
  width:42px;height:42px;
  border-radius:12px;
  background:rgba(255,247,241,0.1);
  display:flex;align-items:center;justify-content:center;
}
.flip-icon .icon{ width:22px;height:22px; color:var(--gold-soft); }
.flip-face--front h3{
  font-family:var(--font-round);
  font-size:16.5px;
  font-weight:700;
  color:var(--cream);
}
.flip-hint{
  font-size:12px;
  font-family:var(--font-round);
  font-weight:600;
  color:var(--cream-dim);
  display:flex;align-items:center;gap:5px;
}
.flip-face--back p{
  font-size:14.5px;
  line-height:1.5;
  font-weight:600;
}

/* ===================================================================
   SUBTABS (Como funciona)
=================================================================== */
.subtabs{
  display:inline-flex;
  background:rgba(255,247,241,0.07);
  border:1px solid var(--line-soft);
  border-radius:999px;
  padding:4px;
  margin-bottom:28px;
  gap:4px;
}
.subtabs button{
  appearance:none; -webkit-appearance:none;
  border:none; background:none;
  font-family:var(--font-round);
  font-weight:700;
  font-size:13.5px;
  color:var(--cream-dim);
  padding:10px 18px;
  border-radius:999px;
  cursor:pointer;
  transition:background .2s var(--ease), color .2s var(--ease);
}
.subtabs button.is-active{
  background:var(--cream);
  color:var(--ink);
}
.subpanel{ display:none; }
.subpanel.is-active{ display:block; animation:fade-up .4s var(--ease); }
@keyframes fade-up{ from{ opacity:0; transform:translateY(8px); } to{ opacity:1; transform:none; } }

.dim-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit, minmax(160px,1fr));
  gap:12px;
}
.dim-card{
  background:rgba(255,247,241,0.06);
  border:1px solid var(--line-soft);
  border-radius:var(--radius-s);
  padding:16px;
  display:flex;
  flex-direction:column;
  gap:10px;
  transition:background .2s var(--ease), transform .2s var(--ease);
}
.dim-card:hover{ background:rgba(255,247,241,0.11); transform:translateY(-2px); }
.dim-card .icon{ width:20px;height:20px; color:var(--gold-soft); }
.dim-card span{ font-size:13.5px; line-height:1.4; font-weight:600; color:var(--cream); }

.tool-list{ display:flex; flex-direction:column; gap:10px; max-width:560px; }
.tool-item{
  display:flex; align-items:center; gap:14px;
  background:rgba(255,247,241,0.06);
  border:1px solid var(--line-soft);
  border-radius:var(--radius-s);
  padding:14px 16px;
  cursor:pointer;
  appearance:none; -webkit-appearance:none;
  font-family:inherit;
  text-align:left;
  width:100%;
  color:var(--cream);
  transition:background .2s var(--ease);
}
.tool-item:hover{ background:rgba(255,247,241,0.1); }
.tool-check{
  width:24px;height:24px;
  border-radius:7px;
  border:1.6px solid var(--line);
  flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  transition:background .2s var(--ease), border-color .2s var(--ease);
}
.tool-check .icon{ width:14px;height:14px; color:var(--ink); opacity:0; transition:opacity .15s var(--ease); }
.tool-item.is-on .tool-check{ background:var(--gold-soft); border-color:var(--gold-soft); }
.tool-item.is-on .tool-check .icon{ opacity:1; }
.tool-item span{ font-size:14.5px; font-weight:600; }
.tool-caption{
  margin-top:18px;
  font-size:13.5px;
  color:var(--cream-dim);
  display:flex; align-items:center; gap:8px;
  opacity:0;
  transition:opacity .3s var(--ease);
}
.tool-caption.is-shown{ opacity:1; }
.tool-caption .icon{ width:16px;height:16px; color:var(--gold-soft); }

/* ===================================================================
   CHIPS (onde atua)
=================================================================== */
.chip-cloud{
  display:flex; flex-wrap:wrap; gap:10px;
}
.chip{
  position:relative;
  appearance:none; -webkit-appearance:none;
  display:inline-flex; align-items:center; gap:8px;
  background:rgba(255,247,241,0.07);
  border:1px solid var(--line-soft);
  color:var(--cream);
  font-family:var(--font-round);
  font-weight:600;
  font-size:14px;
  padding:11px 16px 11px 14px;
  border-radius:999px;
  cursor:pointer;
  transition:background .2s var(--ease), border-color .2s var(--ease), transform .15s var(--ease);
}
.chip .icon{ width:16px;height:16px; color:var(--gold-soft); }
.chip:hover{ transform:translateY(-1px); }
.chip.is-on{
  background:linear-gradient(145deg, var(--gold-soft), var(--gold));
  color:var(--ink);
  border-color:transparent;
}
.chip.is-on .icon{ color:var(--ink); }
.chip-progress{
  margin-top:22px;
  font-size:13.5px;
  font-family:var(--font-round);
  font-weight:600;
  color:var(--cream-dim);
}
.chip-progress strong{ color:var(--gold-soft); }

/* ===================================================================
   QUANDO / FILL BLANK
=================================================================== */
.blank-card{
  margin-top:28px;
  background:rgba(255,247,241,0.06);
  border:1px solid var(--line-soft);
  border-radius:var(--radius-m);
  padding:26px 28px;
  max-width:620px;
}
.blank-sentence{
  font-size:17px;
  line-height:1.6;
  color:var(--cream);
}
.blank-slot{
  display:inline-block;
  min-width:120px;
  border-bottom:2px dashed var(--gold-soft);
  text-align:center;
  font-weight:700;
  color:var(--gold-soft);
}
.blank-options{
  margin-top:18px;
  display:flex; gap:10px; flex-wrap:wrap;
}
.blank-options button{
  appearance:none; -webkit-appearance:none;
  background:rgba(255,247,241,0.08);
  border:1px solid var(--line-soft);
  color:var(--cream);
  font-family:var(--font-round);
  font-weight:600;
  font-size:13.5px;
  padding:10px 16px;
  border-radius:999px;
  cursor:pointer;
}
.blank-options button:hover{ background:rgba(255,247,241,0.14); }
.blank-options button.is-correct{ background:var(--gold-soft); color:var(--ink); border-color:var(--gold-soft); }
.blank-options button.is-wrong{ background:rgba(255,77,94,0.25); border-color:var(--red-bright); }
.blank-feedback{
  margin-top:16px;
  font-size:14px;
  line-height:1.5;
  color:var(--cream-dim);
  display:none;
}
.blank-feedback.is-shown{ display:block; animation:fade-up .3s var(--ease); }

/* ===================================================================
   TRUE / FALSE
=================================================================== */
.tf-card{
  background:rgba(255,247,241,0.06);
  border:1px solid var(--line-soft);
  border-radius:var(--radius-m);
  padding:28px;
  max-width:620px;
}
.tf-statement{
  font-family:var(--font-display);
  font-size:21px;
  line-height:1.4;
  color:var(--cream);
}
.tf-buttons{ margin-top:20px; display:flex; gap:12px; }
.tf-buttons button{
  flex:1;
  appearance:none; -webkit-appearance:none;
  padding:13px 18px;
  border-radius:var(--radius-s);
  font-family:var(--font-round);
  font-weight:700;
  font-size:14.5px;
  cursor:pointer;
  border:1.6px solid var(--line);
  background:rgba(255,247,241,0.06);
  color:var(--cream);
  transition:background .2s var(--ease), border-color .2s var(--ease);
}
.tf-buttons button.is-correct{ background:var(--gold-soft); color:var(--ink); border-color:var(--gold-soft); }
.tf-buttons button.is-wrong{ border-color:var(--red-bright); background:rgba(255,77,94,0.18); }
.tf-result{
  margin-top:18px;
  font-size:14.5px;
  line-height:1.6;
  color:var(--cream-dim);
  display:none;
  border-top:1px solid var(--line-soft);
  padding-top:16px;
}
.tf-result.is-shown{ display:block; animation:fade-up .3s var(--ease); }

.importa-list{
  margin-top:34px;
  display:grid;
  grid-template-columns:repeat(auto-fit, minmax(220px,1fr));
  gap:14px;
}
.importa-item{
  display:flex; gap:12px;
  background:rgba(255,247,241,0.06);
  border:1px solid var(--line-soft);
  border-radius:var(--radius-s);
  padding:16px;
}
.importa-item .icon{ width:19px;height:19px; color:var(--gold-soft); flex-shrink:0; margin-top:2px; }
.importa-item p{ font-size:14px; line-height:1.5; color:var(--cream); }

/* ===================================================================
   QUIZ
=================================================================== */
.quiz-shell{
  background:linear-gradient(160deg, rgba(255,247,241,0.08), rgba(255,247,241,0.02));
  border:1px solid var(--line-soft);
  border-radius:var(--radius-l);
  padding:8px;
}
.quiz-head{
  display:flex; align-items:center; justify-content:space-between;
  flex-wrap:wrap; gap:14px;
  padding:22px 24px 0;
}
.quiz-score{
  font-family:var(--font-round);
  font-weight:800;
  font-size:14px;
  background:rgba(255,247,241,0.08);
  border:1px solid var(--line-soft);
  padding:8px 16px;
  border-radius:999px;
  color:var(--gold-soft);
}
.quiz-body{ padding:22px 24px 26px; }
.quiz-q{ display:none; }
.quiz-q.is-active{ display:block; animation:fade-up .35s var(--ease); }
.quiz-q h3{
  font-family:var(--font-display);
  font-size:21px;
  line-height:1.4;
  color:var(--cream);
  margin-bottom:18px;
}
.quiz-options{ display:flex; flex-direction:column; gap:10px; }
.quiz-options button{
  appearance:none; -webkit-appearance:none;
  text-align:left;
  background:rgba(255,247,241,0.07);
  border:1.6px solid var(--line-soft);
  color:var(--cream);
  font-family:inherit;
  font-size:15px;
  font-weight:500;
  padding:14px 16px;
  border-radius:var(--radius-s);
  cursor:pointer;
  display:flex; align-items:center; gap:10px;
  transition:background .2s var(--ease), border-color .2s var(--ease);
}
.quiz-options button:hover{ background:rgba(255,247,241,0.12); }
.quiz-options button.is-correct{ background:rgba(216,168,87,0.28); border-color:var(--gold-soft); }
.quiz-options button.is-wrong{ background:rgba(255,77,94,0.2); border-color:var(--red-bright); }
.quiz-options button[disabled]{ cursor:default; }
.quiz-options .opt-mark{
  width:20px;height:20px;border-radius:50%;
  border:1.6px solid var(--line);
  flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
}
.quiz-options .opt-mark .icon{ width:12px;height:12px; opacity:0; }
.quiz-options button.is-correct .opt-mark{ background:var(--gold-soft); border-color:var(--gold-soft); }
.quiz-options button.is-correct .opt-mark .icon{ opacity:1; color:var(--ink); }
.quiz-options button.is-wrong .opt-mark .icon{ opacity:1; color:var(--red-bright); }
.quiz-options button.multi.is-selected{ border-color:var(--gold-soft); }

.quiz-feedback{
  margin-top:16px;
  font-size:14px;
  line-height:1.55;
  color:var(--cream-dim);
  min-height:1px;
}
.quiz-foot{
  margin-top:22px;
  display:flex; justify-content:flex-end; gap:10px;
}
.quiz-done{ display:none; text-align:center; padding:10px 6px 18px; }
.quiz-done.is-active{ display:block; animation:fade-up .4s var(--ease); }
.quiz-done .icon{ width:46px;height:46px; color:var(--gold-soft); margin:0 auto 14px; }
.quiz-done h3{ font-size:24px; color:var(--cream); }
.quiz-done p{ margin-top:10px; font-size:15px; color:var(--cream-dim); max-width:46ch; margin-left:auto; margin-right:auto; }
.quiz-done .btn{ margin-top:22px; }

