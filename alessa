<script>
(function(){
  "use strict";

  /* ---------- helpers ---------- */
  function qs(sel, ctx){ return (ctx||document).querySelector(sel); }
  function qsa(sel, ctx){ return Array.prototype.slice.call((ctx||document).querySelectorAll(sel)); }

  function smoothScrollTo(targetEl){
    try{
      var header = qs('.topbar');
      var headerH = header ? header.offsetHeight : 0;
      var top = targetEl.getBoundingClientRect().top + window.pageYOffset - headerH - 14;
      if (window.scrollTo){
        window.scrollTo({ top: top, behavior: 'smooth' });
      } else {
        window.scrollTo(0, top);
      }
    }catch(e){
      try{ targetEl.scrollIntoView(); }catch(e2){ /* no-op */ }
    }
  }

  /* ---------- anchor navigation (nav pills + hero ctas) ---------- */
  try{
    qsa('a[href^="#"]').forEach(function(a){
      a.addEventListener('click', function(ev){
        var id = a.getAttribute('href').slice(1);
        if (!id) return;
        var target = document.getElementById(id);
        if (!target) return;
        ev.preventDefault();
        smoothScrollTo(target);
        try{ history.pushState(null, '', '#' + id); }catch(e){}
      });
    });
  }catch(e){}

  /* ---------- active nav highlighting ---------- */
  try{
    var navLinks = qsa('[data-nav]');
    var navSections = navLinks.map(function(a){ return document.getElementById(a.getAttribute('href').slice(1)); });
    var ticking = false;

    function updateActiveNav(){
      var header = qs('.topbar');
      var headerH = header ? header.offsetHeight : 0;
      var probe = headerH + 24;
      var atBottom = (window.innerHeight + window.pageYOffset) >= (document.documentElement.scrollHeight - 2);
      var activeIdx = 0;
      for (var i = 0; i < navSections.length; i++){
        var sec = navSections[i];
        if (!sec) continue;
        var top = sec.getBoundingClientRect().top;
        if (top <= probe) activeIdx = i;
      }
      if (atBottom) activeIdx = navSections.length - 1;
      navLinks.forEach(function(a, i){ a.classList.toggle('is-active', i === activeIdx); });
      try{
        var activeLink = navLinks[activeIdx];
        if (activeLink && activeLink.scrollIntoView){
          activeLink.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        }
      }catch(e2){}
      ticking = false;
    }

    function onScroll(){
      if (!ticking){
        ticking = true;
        if (window.requestAnimationFrame){ window.requestAnimationFrame(updateActiveNav); }
        else { updateActiveNav(); }
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    updateActiveNav();
  }catch(e){}

  /* ---------- flip cards ---------- */
  try{
    qsa('[data-flip]').forEach(function(btn){
      btn.addEventListener('click', function(){
        var flipped = btn.classList.toggle('is-flipped');
        btn.setAttribute('aria-pressed', flipped ? 'true' : 'false');
        var back = qs('.flip-face--back', btn);
        var front = qs('.flip-face--front', btn);
        if (back) back.setAttribute('aria-hidden', flipped ? 'false' : 'true');
        if (front) front.setAttribute('aria-hidden', flipped ? 'true' : 'false');
      });
    });
  }catch(e){}

  /* ---------- subtabs (Como funciona) ---------- */
  try{
    var tabButtons = qsa('.subtabs [data-tab]');
    tabButtons.forEach(function(btn){
      btn.addEventListener('click', function(){
        var key = btn.getAttribute('data-tab');
        tabButtons.forEach(function(b){
          var active = b === btn;
          b.classList.toggle('is-active', active);
          b.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        qsa('.subpanel').forEach(function(p){
          var show = p.id === 'panel-' + key;
          p.classList.toggle('is-active', show);
          if (show){ p.removeAttribute('hidden'); } else { p.setAttribute('hidden',''); }
        });
      });
    });
  }catch(e){}

  /* ---------- tool checklist ---------- */
  try{
    var toolItems = qsa('[data-tool]');
    var toolCaption = qs('[data-tool-caption]');
    toolItems.forEach(function(item){
      item.addEventListener('click', function(){
        item.classList.toggle('is-on');
        var anyOn = toolItems.some(function(i){ return i.classList.contains('is-on'); });
        if (toolCaption) toolCaption.classList.toggle('is-shown', anyOn);
      });
    });
  }catch(e){}

  /* ---------- chips (onde atua) ---------- */
  try{
    var chips = qsa('[data-chip]');
    var chipProgress = qs('#chip-progress');
    chips.forEach(function(chip){
      chip.addEventListener('click', function(){
        chip.classList.toggle('is-on');
        if (chipProgress){
          var onCount = chips.filter(function(c){ return c.classList.contains('is-on'); }).length;
          chipProgress.innerHTML = '<strong>' + onCount + '</strong> de ' + chips.length + ' setores marcados';
        }
      });
    });
  }catch(e){}

  /* ---------- blank fill (quando ocorre) ---------- */
  try{
    var blankBtns = qsa('#blank-options button');
    var blankSlot = qs('#blank-slot');
    var blankFeedback = qs('#blank-feedback');
    var blankAnswered = false;
    blankBtns.forEach(function(btn){
      btn.addEventListener('click', function(){
        if (blankAnswered) return;
        blankAnswered = true;
        var correct = btn.getAttribute('data-blank') === 'correct';
        btn.classList.add(correct ? 'is-correct' : 'is-wrong');
        if (blankSlot) blankSlot.textContent = btn.textContent;
        blankBtns.forEach(function(b){
          if (b.getAttribute('data-blank') === 'correct') b.classList.add('is-correct');
        });
        if (blankFeedback){
          blankFeedback.textContent = correct
            ? 'Isso mesmo. A periodicidade semestral ou anual é a prática mais comum, embora a lei não fixe um número exato.'
            : 'A resposta mais comum na prática é "semestral ou anual" — destacada acima.';
          blankFeedback.classList.add('is-shown');
        }
      });
    });
  }catch(e){}

  /* ---------- true / false (por que importa) ---------- */
  try{
    var tfBtns = qsa('#tf-buttons button');
    var tfResult = qs('#tf-result');
    var tfAnswered = false;
    tfBtns.forEach(function(btn){
      btn.addEventListener('click', function(){
        if (tfAnswered) return;
        tfAnswered = true;
        var correct = btn.getAttribute('data-tf') === 'correct';
        btn.classList.add(correct ? 'is-correct' : 'is-wrong');
        tfBtns.forEach(function(b){
          if (b.getAttribute('data-tf') === 'correct') b.classList.add('is-correct');
        });
        if (tfResult) tfResult.classList.add('is-shown');
      });
    });
  }catch(e){}

  /* ---------- quiz ---------- */
  try{
    var quizQuestions = qsa('.quiz-q');
    var totalQ = quizQuestions.length;
    var score = 0;
    var currentIndex = 0;
    var scoreEl = qs('#quiz-score');
    var currentEl = qs('#quiz-current');
    var nextWrap = qs('#quiz-next-wrap');
    var nextBtn = qs('#quiz-next-btn');
    var doneEl = qs('#quiz-done');
    var doneTitle = qs('#quiz-done-title');
    var doneText = qs('#quiz-done-text');

    function updateScoreUI(){
      if (scoreEl) scoreEl.textContent = score;
    }

    function showQuestion(idx){
      quizQuestions.forEach(function(q, i){
        q.classList.toggle('is-active', i === idx);
      });
      if (currentEl) currentEl.textContent = idx + 1;
      if (nextWrap) nextWrap.style.display = 'none';
    }

    function finishAnswer(isCorrect, feedbackEl, correctText, wrongText){
      if (isCorrect) score++;
      updateScoreUI();
      if (feedbackEl) feedbackEl.textContent = isCorrect ? correctText : wrongText;
      if (currentIndex < totalQ - 1){
        if (nextWrap) nextWrap.style.display = 'flex';
      } else {
        setTimeout(showResult, 550);
      }
    }

    function showResult(){
      quizQuestions.forEach(function(q){ q.classList.remove('is-active'); });
      if (doneEl){
        doneEl.classList.add('is-active');
        if (doneTitle) doneTitle.textContent = 'Resultado: ' + score + ' de ' + totalQ;
        if (doneText){
          doneText.textContent = score >= 3
            ? 'Você já sabe o suficiente sobre a CPA para participar com segurança.'
            : 'Vale revisar as seções acima — mas isso não te impede de participar agora mesmo.';
        }
      }
    }

    /* single-select questions: 1, 3, 4 */
    [1,3,4].forEach(function(qNum){
      var qEl = qs('.quiz-q[data-q="' + qNum + '"]');
      if (!qEl) return;
      var feedbackEl = qs('.quiz-feedback', qEl);
      var optionBtns = qsa('.quiz-options button', qEl);
      var answered = false;
      optionBtns.forEach(function(btn){
        btn.addEventListener('click', function(){
          if (answered) return;
          answered = true;
          var isCorrect = btn.getAttribute('data-correct') === 'true';
          optionBtns.forEach(function(b){
            b.disabled = true;
            if (b.getAttribute('data-correct') === 'true') b.classList.add('is-correct');
            else if (b === btn) b.classList.add('is-wrong');
          });
          finishAnswer(isCorrect, feedbackEl,
            'Isso mesmo.',
            'Essa não é a alternativa correta — a opção certa está destacada acima.');
        });
      });
    });

    /* multi-select question: 2 */
    (function(){
      var qEl = qs('.quiz-q[data-q="2"]');
      if (!qEl) return;
      var feedbackEl = qs('.quiz-feedback', qEl);
      var optionBtns = qsa('#q2-options button');
      var confirmBtn = qs('#q2-confirm');
      var confirmed = false;
      optionBtns.forEach(function(btn){
        btn.addEventListener('click', function(){
          if (confirmed) return;
          btn.classList.toggle('is-selected');
        });
      });
      if (confirmBtn){
        confirmBtn.addEventListener('click', function(){
          if (confirmed) return;
          confirmed = true;
          var allRight = optionBtns.every(function(b){
            var shouldBeOn = b.getAttribute('data-correct') === 'true';
            var isOn = b.classList.contains('is-selected');
            return shouldBeOn === isOn;
          });
          optionBtns.forEach(function(b){
            b.disabled = true;
            var shouldBeOn = b.getAttribute('data-correct') === 'true';
            if (shouldBeOn) b.classList.add('is-correct');
            else if (b.classList.contains('is-selected')) b.classList.add('is-wrong');
          });
          confirmBtn.style.display = 'none';
          finishAnswer(allRight, feedbackEl,
            'Isso mesmo: docentes, discentes, técnicos-administrativos e sociedade civil organizada.',
            'A composição correta é: docentes, discentes, técnicos-administrativos e sociedade civil organizada — destacados acima.');
        });
      }
    })();

    if (nextBtn){
      nextBtn.addEventListener('click', function(){
        currentIndex++;
        showQuestion(currentIndex);
      });
    }

    updateScoreUI();
  }catch(e){}

})();
</script>


</body>
</html>
